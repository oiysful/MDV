{
  "name": "mdv",
  "version": "1.0.0",
  "description": "Claude-style Markdown Editor",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "install:local": "bash scripts/install-local.sh",
    "update:local": "bash scripts/update-local.sh",
    "install:release": "bash scripts/install-release.sh",
    "update:release": "bash scripts/update-release.sh",
    "test:electron": "node --test tests/electron/smoke.test.js",
    "test:unit": "node --test tests/unit/*.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "chokidar": "^5.0.0"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "playwright": "^1.60.0"
  },
  "build": {
    "appId": "com.ian.mdv",
    "productName": "MDV",
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown",
        "role": "Editor"
      }
    ],
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  }
}
