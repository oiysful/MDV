{
  "name": "mdv",
  "version": "1.0.2",
  "description": "Claude-style Markdown Editor",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "install:local": "bash scripts/install-local.sh",
    "update:local": "bash scripts/update-local.sh",
    "install:release": "bash scripts/install-release.sh",
    "update:release": "bash scripts/update-release.sh",
    "test:electron": "node --test tests/electron/smoke.test.js",
    "test:e2e": "node --test --test-name-pattern=\"${E2E:-.}\" tests/electron/smoke.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:controller": "node --test tests/controller/*.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@highlightjs/cdn-assets": "^11.11.1",
    "chokidar": "^5.0.0",
    "dompurify": "^3.4.11",
    "marked": "^9.1.6"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0"
  },
  "build": {
    "appId": "com.ian.mdv",
    "productName": "MDV",
    "mac": {
      "target": "zip",
      "icon": "assets/icon.icns"
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown",
        "role": "Editor"
      }
    ],
    "files": [
      "src/**/*",
      "assets/**/*"
    ]
  }
}
